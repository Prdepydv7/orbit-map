{
  "version": 8,
  "name": "Dyntrix Hybrid Satellite",
  "sources": {
    "satellite-source": {
      "type": "raster",
      "tiles": ["https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}"],
      "tileSize": 256
    },
    "orbit-india-source": {
      "type": "vector",
      "url": "pmtiles://https://orbit-map-server.netlify.app/india_map.pmtiles"
    }
  },
  "layers": [
    {
      "id": "satellite-layer",
      "type": "raster",
      "source": "satellite-source",
      "minzoom": 0,
      "maxzoom": 22
    },
    {
      "id": "orbit-roads",
      "type": "line",
      "source": "orbit-india-source",
      "source-layer": "transportation",
      "paint": {
        "line-color": "#00F2FE", 
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          10, 2.0,
          14, 4.5,
          18, 8.0
        ],
        "line-opacity": 0.9,
        "line-blur": 0.5
      }
    },
    {
      "id": "3d-buildings-all",
      "type": "fill-extrusion",
      "source": "orbit-india-source",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-extrusion-color": "#22D3EE", 
        
        "fill-extrusion-height": [
          "coalesce",
          ["data-driven"],
          ["get", "render_height"],
          ["get", "height"],
          25
        ],
        "fill-extrusion-base": 0,
        "fill-extrusion-opacity": 0.7
      }
    }
  ]
}